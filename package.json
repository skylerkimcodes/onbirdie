{
  "name": "onbirdie",
  "displayName": "OnBirdie",
  "description": "Multi-agent onboarding that guides new hires into productive engineers.",
  "version": "0.0.1",
  "publisher": "onbirdie",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:onbirdie.sidebar",
    "onCommand:onbirdie.styleReviewStaged"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "onbirdie",
          "title": "OnBirdie",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "onbirdie": [
        {
          "type": "webview",
          "id": "onbirdie.sidebar",
          "name": "OnBirdie"
        }
      ]
    },
    "configuration": {
      "title": "OnBirdie",
      "properties": {
        "onbirdie.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "OnBirdie API base URL (no trailing slash)."
        },
        "onbirdie.styleReviewOnCommit": {
          "type": "boolean",
          "default": true,
          "description": "After each git commit, run style review on the committed patch (requires sign-in)."
        },
        "onbirdie.liveStyleCheck": {
          "type": "boolean",
          "default": true,
          "description": "While editing, debounce-call the style API and show findings in Problems (uses Microsoft demo guide when enabled on server)."
        },
        "onbirdie.liveStyleDebounceMs": {
          "type": "number",
          "default": 1400,
          "minimum": 400,
          "maximum": 60000,
          "description": "Milliseconds to wait after typing before running a live style check."
        }
      }
    },
    "commands": [
      {
        "command": "onbirdie.welcome",
        "title": "OnBirdie: Open welcome"
      },
      {
        "command": "onbirdie.styleReviewStaged",
        "title": "OnBirdie: Review staged changes (style guide)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "tsc -p ./",
    "compile:webview": "esbuild src/webview/sidebar/index.tsx --bundle --outfile=out/webview/sidebar.js --loader:.tsx=tsx --loader:.ts=ts",
    "watch": "run-p watch:ext watch:webview",
    "watch:ext": "tsc -watch -p ./",
    "watch:webview": "esbuild src/webview/sidebar/index.tsx --bundle --outfile=out/webview/sidebar.js --loader:.tsx=tsx --loader:.ts=ts --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.4",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
