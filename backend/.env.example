# MongoDB Atlas (include database name or set MONGODB_DB_NAME)
MONGODB_URI=
MONGODB_DB_NAME=onbirdie

# JWT signing secret for login tokens (use a long random string in production)
JWT_SECRET=change-me-in-production

# Optional: extra employer seeded on startup (default join code "onbirdie" is always created)
# BOOTSTRAP_EMPLOYER_NAME=Acme Corp
# BOOTSTRAP_EMPLOYER_JOIN_CODE=ACME-2026

# Chat LLM — Lava AI Gateway (recommended; bills your Lava wallet)
# Docs: https://lava.so/docs/gateway/forward-proxy
LAVA_SECRET_KEY=
LAVA_API_BASE_URL=https://api.lava.so/v1
# Full upstream URL Lava forwards to (OpenAI Chat Completions)
LAVA_FORWARD_UPSTREAM=https://api.openai.com/v1/chat/completions

# Model id for chat + default light-tier style review (must match Lava / upstream)
CHAT_MODEL=gpt-4o-mini
# Optional: override model for style-review light tier only (else CHAT_MODEL is used)
LAVA_LIGHT_MODEL=
# Optional BYOK for LAVA_FORWARD_UPSTREAM (forward token with provider_key)
LAVA_LIGHT_PROVIDER_KEY=

# Fallback if LAVA_SECRET_KEY is unset — K2 or OpenAI
K2_BASE_URL=
K2_API_KEY=
K2_MODEL=k2-think-v2
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Style review: lava_light (default) | k2
STYLE_REVIEW_TIER=lava_light

# Demo: use built-in Microsoft-style guide text (set false to use employer.style_guide from MongoDB)
STYLE_GUIDE_USE_MICROSOFT_DEMO=true
