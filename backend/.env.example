# MongoDB Atlas (include database name or set MONGODB_DB_NAME)
MONGODB_URI=
MONGODB_DB_NAME=onbirdie

# JWT signing secret for login tokens (use a long random string in production)
JWT_SECRET=change-me-in-production

# Optional: extra employer seeded on startup (default join code "onbirdie" is always created)
# BOOTSTRAP_EMPLOYER_NAME=Acme Corp
# BOOTSTRAP_EMPLOYER_JOIN_CODE=ACME-2026

# --- LLM routing ---
# If K2_BASE_URL + K2_API_KEY are set → chat, plan JSON, and tour use K2 (K2_MODEL).
# Else if LAVA_SECRET_KEY → those features use Lava + LAVA_CHAT_MODEL / CHAT_MODEL.
# Else → OPENAI_API_KEY (+ optional OPENAI_BASE_URL) with CHAT_MODEL.
# Lava is a forward proxy to an upstream URL, not a model id. https://lava.so/docs/gateway/forward-proxy
LAVA_SECRET_KEY=
LAVA_API_BASE_URL=https://api.lava.so/v1
LAVA_FORWARD_UPSTREAM=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# Model id when chat uses Lava (must match upstream)
LAVA_CHAT_MODEL=gemini-2.0-flash

CHAT_MODEL=gpt-4o-mini
# Style-review light tier: LAVA_LIGHT_MODEL or else CHAT_MODEL (see STYLE_REVIEW_TIER)
LAVA_LIGHT_MODEL=
LAVA_LIGHT_PROVIDER_KEY=

K2_BASE_URL=
K2_API_KEY=
K2_MODEL=MBZUAI-IFM/K2-Think-v2
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Style review: lava_light (Lava + cheap model) | k2 (reviews on K2 too)
STYLE_REVIEW_TIER=lava_light

# Demo: use built-in Microsoft-style coding conventions (set false to use employer.style_guide from MongoDB)
STYLE_GUIDE_USE_MICROSOFT_DEMO=true
