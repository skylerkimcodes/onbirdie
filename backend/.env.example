# MongoDB Atlas (connection string with vector search enabled cluster)
MONGODB_URI=

# Auth0 (API audience + domain for JWKS)
# Domain: Auth0 Dashboard → Settings → Domain
AUTH0_DOMAIN=your-tenant.us.auth0.com
# Audience: custom API Identifier (Auth0 → APIs), or Management API: https://YOUR_DOMAIN/api/v2/
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# K2 Think V2 — OpenAI-compatible endpoint (from MBZUAI / your gateway)
K2_BASE_URL=
K2_API_KEY=

# Lava (secret key / forward tokens — see https://lava.so/docs)
LAVA_SECRET_KEY=
LAVA_API_BASE_URL=
